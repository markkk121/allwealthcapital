// ── SCROLL REVEAL


function initHomeTVWidget(sym){
  sym=sym||'BITSTAMP:BTCUSD';
  const c=document.getElementById('home-tv-widget');
  if(!c)return;
  c.innerHTML='';
  const s=document.createElement('script');
  s.src='https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js';
  s.async=true;
  s.innerHTML=JSON.stringify({
    autosize:true,symbol:sym,interval:'D',timezone:'Etc/UTC',
    theme:'dark',style:'1',locale:'en',hide_top_toolbar:false,
    backgroundColor:'rgba(18,21,58,1)',gridColor:'rgba(255,255,255,0.04)'
  });
  c.appendChild(s);
}
function switchTVSymbol(sym,btn){
  document.querySelectorAll('.market-sec .cc-tab, #dtab-dashboard .cc-tab').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  const iframe=document.getElementById('home-tv-widget');
  if(iframe){
    const enc=encodeURIComponent(sym);
    iframe.src=`https://s.tradingview.com/widgetembed/?frameElementId=home-tv-widget&symbol=${enc}&interval=D&hidesidetoolbar=0&symboledit=1&saveimage=1&toolbarbg=1a1e45&theme=dark&style=1&timezone=Etc%2FUTC&locale=en`;
  }
  if(document.getElementById('tv-widget-container'))loadTVWidget(sym);
}

// ── LIVE TICKER
const FINNHUB_KEY='d6gmkupr01qldjjblv5gd6gmkupr01qldjjblv60';
const TICKER_SYMS=[
  {s:'BINANCE:BTCUSDT',label:'BTC/USD'},
  {s:'BINANCE:ETHUSDT',label:'ETH/USD'},
  {s:'BINANCE:SOLUSDT',label:'SOL/USD'},
  {s:'BINANCE:BNBUSDT',label:'BNB/USD'},
  {s:'OANDA:EURUSD',label:'EUR/USD'},
  {s:'OANDA:GBPUSD',label:'GBP/USD'},
  {s:'NASDAQ:AAPL',label:'AAPL'},
  {s:'NASDAQ:TSLA',label:'TSLA'},
  {s:'NASDAQ:NVDA',label:'NVDA'},
];
async function loadTicker(){
  const track=document.getElementById('tickerTrack');
  if(!track)return;
  const items=await Promise.all(TICKER_SYMS.map(async t=>{
    try{
      const r=await fetch(`https://finnhub.io/api/v1/quote?symbol=${t.s}&token=${FINNHUB_KEY}`);
      const d=await r.json();
      if(d&&d.c){
        const chg=d.c-d.pc;
        const pct=(chg/d.pc*100).toFixed(2);
        const col=chg>=0?'#10b981':'#ef4444';
        const arrow=chg>=0?'▲':'▼';
        return `<span class="ticker-item"><span style="color:var(--blue2);font-weight:700">${t.label}</span><span style="color:var(--white)">${d.c.toLocaleString()}</span><span style="color:${col}">${arrow}${Math.abs(pct)}%</span></span>`;
      }
    }catch(e){}
    return `<span class="ticker-item"><span style="color:var(--blue2);font-weight:700">${t.label}</span><span style="color:var(--gray)">—</span></span>`;
  }));
  const content=items.join('');
  track.innerHTML=content+content;
}

