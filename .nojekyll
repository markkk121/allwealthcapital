</nav>

<!-- TICKER -->
<div class="ticker-bar">
  <div class="ticker-track" id="tickerTrack">
    <span style="font-family:var(--mono);font-size:0.65rem;color:var(--gray);padding:0 2rem">Loading markets…</span>
  </div>
</div>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-dots"></div>
  <div class="hero-content">
    <div class="hero-eyebrow"><div class="hero-dot"></div> Professional Investment Management</div>
    <h1>Trade Crypto, Forex<br>&amp; <span class="hl">Stocks</span> Like a Pro</h1>
    <p class="hero-sub">Tabuwul FX is your trusted partner for high-performance trading and investment across global markets. Guaranteed ROIs, instant withdrawals, and 24/7 support.</p>
