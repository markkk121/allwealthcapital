    </div>
    <div class="plan-card hot reveal">
      <div class="plan-hot-tag">MOST POPULAR</div>
      <div class="plan-icon-wrap">📈</div>
      <div class="plan-name">Growth Tier</div>
      <div class="plan-min">Minimum amount: $10,000</div>
      <div class="plan-max">Maximum amount: $99,999</div>
      <div class="plan-roi">15% Weekly for 12 Weeks</div>
      <button class="plan-btn" onclick="openModal('signup')">Suscribe to Plan</button>
    </div>
    <div class="plan-card reveal">
      <div class="plan-icon-wrap">💎</div>
      <div class="plan-name">Elite Tier</div>
      <div class="plan-min">Minimum amount: $500,000</div>
      <div class="plan-max">Maximum amount: $2,999,999</div>
      <div class="plan-roi">30% Weekly for 12 Weeks</div>
      <button class="plan-btn" onclick="openModal('signup')">Suscribe to Plan</button>
    </div>
    <div class="plan-card reveal">
      <div class="plan-icon-wrap">🏆</div>
      <div class="plan-name">Prime Tier</div>
      <div class="plan-min">Minimum amount: $100,000</div>
      <div class="plan-max">Maximum amount: $499,999</div>
      <div class="plan-roi">20% Weekly for 12 Weeks</div>
      <button class="plan-btn" onclick="openModal('signup')">Suscribe to Plan</button>
