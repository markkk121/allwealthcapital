<!DOCTYPE html>
<!-- nojekyll -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta http-equiv="Content-Security-Policy" content="default-src *; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data: blob:; frame-src *; connect-src *;">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tabuwul FX | Crypto · Forex · Stocks</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◈</text></svg>">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0d0f2b;--navy2:#12153a;--navy3:#1a1e45;
  --blue:#4f46e5;--blue2:#6366f1;--blue3:rgba(79,70,229,0.15);
  --gold:#f59e0b;--green:#10b981;--red:#ef4444;
  --white:#ffffff;--gray:#9ca3af;--gray2:#6b7280;
  --border:rgba(255,255,255,0.08);--border2:rgba(79,70,229,0.3);
  --font:'Poppins',sans-serif;--mono:'Roboto Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--navy);color:var(--white);font-family:var(--font);overflow-x:hidden}

/* DOTTED BACKGROUND PATTERN */
.dots-bg{background-image:radial-gradient(rgba(255,255,255,0.06) 1px,transparent 1px);background-size:24px 24px}

/* TOP BAR */
.topbar{background:var(--navy2);border-bottom:1px solid var(--border);padding:0.4rem 3rem;display:flex;justify-content:flex-end;align-items:center;gap:2rem;font-size:0.72rem;color:var(--gray)}
.topbar a{color:var(--gray);text-decoration:none}
.topbar a:hover{color:var(--white)}

/* NAV */
nav{background:var(--navy2);border-bottom:1px solid var(--border);padding:1rem 3rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,0.3)}
.logo{display:flex;align-items:center;gap:0.6rem;cursor:pointer;text-decoration:none}
.logo-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--blue),var(--blue2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.logo-text{font-size:1.1rem;font-weight:700;color:var(--white)}
.logo-text span{color:var(--blue2)}
.nav-links{display:flex;gap:0.3rem;list-style:none;align-items:center}
.nav-links a{color:var(--gray);text-decoration:none;font-size:0.88rem;font-weight:500;padding:0.5rem 0.9rem;border-radius:6px;transition:all 0.2s}
.nav-links a:hover,.nav-links a.active{color:var(--white);background:var(--blue3)}
.hot-badge{background:#ef4444;color:#fff;font-size:0.55rem;font-weight:700;padding:0.1rem 0.4rem;border-radius:3px;margin-left:0.3rem;vertical-align:middle}
.nav-right{display:flex;gap:0.8rem;align-items:center}
.btn-nav-signin{background:none;border:1px solid var(--border2);color:var(--blue2);font-family:var(--font);font-size:0.82rem;font-weight:600;padding:0.5rem 1.2rem;border-radius:6px;cursor:pointer;transition:all 0.2s}
.btn-nav-signin:hover{background:var(--blue3)}
.btn-nav-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.82rem;font-weight:600;padding:0.5rem 1.4rem;border:none;border-radius:6px;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 15px rgba(79,70,229,0.3)}
.btn-nav-primary:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(79,70,229,0.4)}
#navUserBar{display:none;align-items:center;gap:0.8rem;font-size:0.82rem}
#navEmailDisplay{color:var(--gray);font-size:0.78rem}

/* PAGES */
.page{display:none}.page.active{display:block}

/* TICKER */
.ticker-bar{background:var(--navy3);border-bottom:1px solid var(--border);padding:0.6rem 0;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-flex;gap:2.5rem;animation:tickScroll 35s linear infinite}
.ticker-track:hover{animation-play-state:paused}
.ticker-item{font-family:var(--mono);font-size:0.65rem;display:flex;align-items:center;gap:0.5rem}
.t-sym{color:var(--white);font-weight:500}
.t-price{color:var(--gray)}
.t-up{color:var(--green)}
.t-down{color:var(--red)}
@keyframes tickScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ══ HERO ══ */
.hero{position:relative;min-height:92vh;display:flex;align-items:center;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0d0f2b 0%,#1a1e45 40%,#0d0f2b 100%);z-index:0}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(110deg,rgba(13,15,43,0.95) 45%,rgba(13,15,43,0.7) 100%)}
.hero-dots{position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:28px 28px}
.hero-content{position:relative;z-index:2;padding:0 3rem;max-width:700px}
.hero-eyebrow{font-size:0.78rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--blue2);margin-bottom:1.2rem;display:flex;align-items:center;gap:0.6rem}
.hero-dot{width:8px;height:8px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,0.4)}50%{box-shadow:0 0 0 8px rgba(16,185,129,0)}}
.hero h1{font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;line-height:1.1;margin-bottom:1.2rem}
.hero h1 .hl{color:var(--blue2)}
.hero-sub{font-size:1rem;color:var(--gray);line-height:1.8;margin-bottom:2rem;max-width:48ch}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3rem}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.9rem;font-weight:600;padding:0.9rem 2rem;border:none;border-radius:8px;cursor:pointer;transition:all 0.3s;box-shadow:0 4px 20px rgba(79,70,229,0.35);position:relative;overflow:hidden}
.btn-primary::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);transform:translateX(-100%);transition:transform 0.5s}
.btn-primary:hover::after{transform:translateX(100%)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(79,70,229,0.5)}
.btn-outline{background:none;border:1px solid var(--border2);color:var(--blue2);font-family:var(--font);font-size:0.9rem;font-weight:600;padding:0.9rem 2rem;border-radius:8px;cursor:pointer;transition:all 0.3s;text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem}
.btn-outline:hover{background:var(--blue3)}
.hero-stats{display:flex;gap:2.5rem}
.hstat{display:flex;flex-direction:column}
.hstat-val{font-size:1.6rem;font-weight:800;color:var(--white)}
.hstat-lbl{font-size:0.7rem;color:var(--gray);margin-top:0.1rem}
.hero-float{position:absolute;right:3rem;top:50%;transform:translateY(-50%);z-index:2;display:flex;flex-direction:column;gap:1rem}
.hf-card{background:rgba(13,15,43,0.85);border:1px solid var(--border2);backdrop-filter:blur(16px);padding:1rem 1.3rem;border-radius:12px;display:flex;align-items:center;gap:1rem;min-width:210px;animation:floatY 4s ease-in-out infinite}
.hf-card:nth-child(2){animation-delay:1.5s}.hf-card:nth-child(3){animation-delay:3s}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.hf-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;flex-shrink:0}
.hf-btc{background:rgba(247,147,26,0.2);color:#f7931a}
.hf-eth{background:rgba(98,126,234,0.2);color:#627eea}
.hf-sol{background:rgba(20,241,149,0.2);color:#14f195}
.hf-info .hf-name{font-weight:600;font-size:0.88rem}
.hf-info .hf-price{font-size:0.78rem;color:var(--gray);font-family:var(--mono)}
.hf-chg{font-family:var(--mono);font-size:0.72rem;font-weight:600}
.hf-up{color:var(--green)}.hf-dn{color:var(--red)}

/* ══ SECTION COMMON ══ */
.section{padding:5.5rem 3rem}
.s-eyebrow{font-size:0.75rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--blue2);margin-bottom:0.8rem}
.s-title{font-size:clamp(1.7rem,3.5vw,2.6rem);font-weight:800;line-height:1.15;margin-bottom:1.2rem}
.s-title .hl{color:var(--blue2)}
.s-divider{width:60px;height:3px;background:linear-gradient(90deg,var(--blue),var(--blue2));border-radius:2px;margin:1rem auto 0}
.s-center{text-align:center}
.reveal{opacity:1;transform:none;transition:opacity 0.7s,transform 0.7s}
.reveal.visible{opacity:1;transform:none}
.reveal-l{opacity:1;transform:none;transition:opacity 0.7s,transform 0.7s}
.reveal-l.visible{opacity:1;transform:none}
.reveal-r{opacity:1;transform:none;transition:opacity 0.7s,transform 0.7s}
.reveal-r.visible{opacity:1;transform:none}

/* ══ ABOUT ══ */
.about-sec{background:var(--navy2);border-top:1px solid var(--border)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:3rem}
.about-img-wrap{position:relative}
.about-photo{width:100%;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,var(--navy3),var(--blue3));aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;font-size:7rem;border:1px solid var(--border2)}
.about-badge-box{position:absolute;bottom:-1.2rem;right:-1.2rem;background:linear-gradient(135deg,var(--blue),var(--blue2));border-radius:10px;padding:1.2rem 1.5rem;text-align:center;box-shadow:0 8px 30px rgba(79,70,229,0.4)}
.about-badge-val{font-size:1.8rem;font-weight:800;color:#fff}
.about-badge-lbl{font-size:0.65rem;color:rgba(255,255,255,0.8);margin-top:0.1rem}
.about-body{font-size:0.9rem;color:var(--gray);line-height:1.9;margin-bottom:1.8rem}
.about-checks{display:grid;grid-template-columns:1fr 1fr;gap:0.9rem;margin-bottom:2rem}
.check-item{display:flex;align-items:center;gap:0.7rem;font-size:0.85rem;font-weight:500}
.check-icon{width:22px;height:22px;background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--green);font-size:0.65rem;flex-shrink:0}

/* ══ HOW IT WORKS ══ */
.hiw-sec{background:var(--navy) dots-bg;position:relative;overflow:hidden}
.hiw-sec::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:24px 24px}
.hiw-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:3rem;margin-top:3.5rem;position:relative}
.hiw-steps::before{content:'';position:absolute;top:2.5rem;left:16%;right:16%;height:2px;background:linear-gradient(90deg,var(--blue),var(--blue2),var(--blue));opacity:0.3}
.hiw-step{text-align:center;padding:0 1rem;position:relative}
.step-circle{width:56px;height:56px;background:linear-gradient(135deg,var(--blue),var(--blue2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;margin:0 auto 1.5rem;box-shadow:0 4px 20px rgba(79,70,229,0.4);transition:transform 0.3s}
.hiw-step:hover .step-circle{transform:scale(1.1)}
.step-title{font-size:1.05rem;font-weight:700;margin-bottom:0.7rem;text-transform:uppercase;letter-spacing:0.05em}
.step-desc{font-size:0.82rem;color:var(--gray);line-height:1.8}

/* ══ WHAT WE DO ══ */
.wwd-sec{background:linear-gradient(180deg,var(--navy2) 0%,var(--navy3) 100%);border-top:1px solid var(--border);position:relative;overflow:hidden}
.wwd-sec::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.03) 1px,transparent 1px);background-size:24px 24px}
.wwd-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:3rem;border:1px dashed rgba(255,255,255,0.1)}
.wwd-card{padding:2.5rem 2rem;border-right:1px dashed rgba(255,255,255,0.1);border-bottom:1px dashed rgba(255,255,255,0.1);transition:background 0.3s;text-align:center;position:relative}
.wwd-card:nth-child(3n){border-right:none}
.wwd-card:nth-last-child(-n+3){border-bottom:none}
.wwd-card:hover{background:rgba(79,70,229,0.06)}
.wwd-icon{font-size:2.8rem;margin-bottom:1.2rem;display:block;opacity:0.85}
.wwd-title{font-size:1rem;font-weight:700;margin-bottom:0.7rem}
.wwd-desc{font-size:0.8rem;color:var(--gray);line-height:1.8}

/* ══ INVESTMENT PLANS ══ */
.plans-sec{background:linear-gradient(180deg,var(--navy3) 0%,var(--navy2) 100%);border-top:1px solid var(--border);position:relative;overflow:hidden}
.plans-sec::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.03) 1px,transparent 1px);background-size:24px 24px}
.plans-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem}
.plan-card{border:1px dashed rgba(255,255,255,0.12);padding:2.5rem 2rem;text-align:center;transition:all 0.4s;position:relative;border-radius:4px;background:rgba(255,255,255,0.02)}
.plan-card:hover{background:rgba(79,70,229,0.08);border-color:var(--border2);transform:translateY(-6px)}
.plan-card.hot{border-color:var(--blue2);background:rgba(79,70,229,0.08)}
.plan-hot-tag{position:absolute;top:-0.7rem;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,var(--blue),var(--blue2));color:#fff;font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.25rem 0.9rem;border-radius:20px}
.plan-icon-wrap{width:64px;height:64px;border:1px dashed var(--border2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;margin:0 auto 1.2rem}
.plan-name{font-size:1.2rem;font-weight:800;margin-bottom:0.5rem}
.plan-min{font-size:0.8rem;color:var(--gray);margin-bottom:0.2rem}
.plan-max{font-size:0.8rem;color:var(--gray);margin-bottom:1rem}
.plan-roi{font-size:1.1rem;color:var(--blue2);font-weight:700;margin-bottom:1.5rem}
.plan-btn{display:block;width:100%;background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.82rem;font-weight:600;padding:0.75rem;border:none;border-radius:6px;cursor:pointer;transition:all 0.3s}
.plan-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(79,70,229,0.4)}

/* ══ SERVICES ══ */
.services-sec{background:var(--navy);border-top:1px solid var(--border)}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem}
.svc-card{border:1px solid var(--border);border-radius:8px;overflow:hidden;transition:all 0.3s}
.svc-card:hover{transform:translateY(-4px);border-color:var(--border2);box-shadow:0 12px 40px rgba(0,0,0,0.3)}
.svc-img{aspect-ratio:16/9;background:linear-gradient(135deg,var(--navy3),rgba(79,70,229,0.2));display:flex;align-items:center;justify-content:center;font-size:4rem;border-bottom:1px solid var(--border)}
.svc-body{padding:1.5rem}
.svc-title{font-size:1rem;font-weight:700;margin-bottom:0.6rem}
.svc-desc{font-size:0.8rem;color:var(--gray);line-height:1.8}

/* ══ MARKET PRICES (CryptoCompare) ══ */
.market-sec{background:var(--navy2);border-top:1px solid var(--border)}
.cc-wrap{background:var(--navy3);border:1px solid var(--border);border-radius:8px;padding:1.5rem;margin-top:2rem}
.cc-tabs{display:flex;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
.cc-tab{background:none;border:1px solid var(--border);color:var(--gray);font-family:var(--font);font-size:0.78rem;font-weight:600;padding:0.4rem 1rem;border-radius:6px;cursor:pointer;transition:all 0.2s}
.cc-tab.active{background:linear-gradient(135deg,var(--blue),var(--blue2));border-color:transparent;color:#fff}
.cc-cur-btns{display:flex;gap:0.5rem;margin-bottom:1.2rem}
.cc-cur{background:none;border:1px solid var(--border);color:var(--gray);font-size:0.78rem;font-weight:700;padding:0.3rem 0.8rem;border-radius:4px;cursor:pointer;font-family:var(--font);transition:all 0.2s}
.cc-cur.active{border-color:var(--gold);color:var(--gold)}
.cc-time-btns{display:flex;gap:0.5rem;margin-bottom:1.5rem}
.cc-time{background:none;border:1px solid var(--border);color:var(--gray);font-size:0.72rem;padding:0.25rem 0.7rem;border-radius:4px;cursor:pointer;font-family:var(--mono);transition:all 0.2s}
.cc-time.active{border-color:var(--blue2);color:var(--blue2)}
#ccChart{width:100%;height:280px}
.cc-price-lbl{font-family:var(--mono);font-size:0.78rem;color:var(--gray);margin-bottom:0.5rem}
.cc-price-val{font-family:var(--mono);font-size:1.6rem;font-weight:700;color:var(--white);margin-bottom:1rem}

/* ══ TEAM ══ */
.team-sec{background:var(--navy);border-top:1px solid var(--border);position:relative;overflow:hidden}
.team-sec::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:24px 24px}
.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem}
.team-card{text-align:center;transition:transform 0.3s}
.team-card:hover{transform:translateY(-4px)}
.team-photo{width:100%;aspect-ratio:3/4;border-radius:10px;overflow:hidden;background:linear-gradient(135deg,var(--navy3),rgba(79,70,229,0.2));display:flex;align-items:center;justify-content:center;font-size:5rem;border:1px solid var(--border);margin-bottom:1.2rem}
.team-name{font-size:1.05rem;font-weight:700;margin-bottom:0.3rem}
.team-role{font-size:0.8rem;color:var(--blue2);font-weight:600}

/* ══ FAQ ══ */
.faq-sec{background:var(--navy2);border-top:1px solid var(--border)}
.faq-list{max-width:820px;margin:3rem auto 0;display:flex;flex-direction:column;gap:0.6rem}
.faq-item{background:var(--navy3);border-radius:6px;overflow:hidden;border:1px solid var(--border);transition:border-color 0.3s}
.faq-item.open{border-color:var(--border2)}
.faq-q{display:flex;justify-content:space-between;align-items:center;padding:1.1rem 1.5rem;cursor:pointer;font-size:0.92rem;font-weight:600;gap:1rem;transition:color 0.2s}
.faq-q:hover{color:var(--blue2)}
.faq-icon{color:var(--blue2);font-size:1.3rem;font-weight:300;transition:transform 0.3s;flex-shrink:0}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-a{font-size:0.82rem;color:var(--gray);line-height:1.9;padding:0 1.5rem;max-height:0;overflow:hidden;transition:max-height 0.4s,padding 0.3s}
.faq-item.open .faq-a{max-height:250px;padding:0 1.5rem 1.2rem}

/* ══ LIVE EARNINGS NOTIF ══ */
#earn-notif{position:fixed;bottom:6rem;left:1.5rem;z-index:500;background:var(--navy2);border:1px solid var(--border2);border-left:3px solid var(--blue2);border-radius:8px;padding:0.9rem 1.2rem;max-width:270px;display:flex;align-items:center;gap:0.9rem;transform:translateX(-120%);transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1);box-shadow:0 8px 30px rgba(0,0,0,0.5)}
#earn-notif.show{transform:translateX(0)}
.en-logo{width:36px;height:36px;background:linear-gradient(135deg,var(--blue),var(--blue2));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.en-content{font-size:0.72rem;line-height:1.6}
.en-name{color:var(--blue2);font-weight:700}
.en-country{color:var(--green);font-weight:600}
.en-amount{color:var(--gold);font-size:0.82rem;font-weight:700}

/* ══ WHATSAPP ══ */
#wa-btn{position:fixed;bottom:1.5rem;right:1.5rem;z-index:400;width:54px;height:54px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;cursor:pointer;box-shadow:0 4px 20px rgba(37,211,102,0.4);transition:all 0.3s;text-decoration:none;animation:waPulse 3s infinite}
#wa-btn:hover{transform:scale(1.1)}
@keyframes waPulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.4)}50%{box-shadow:0 4px 20px rgba(37,211,102,0.4),0 0 0 8px rgba(37,211,102,0.08)}}

/* ══ AUTH MODAL ══ */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(8px)}
.modal-ov.open{display:flex}
.modal-box{background:var(--navy2);border:1px solid var(--border2);border-radius:12px;padding:2.5rem;width:100%;max-width:400px;position:relative;animation:popIn 0.3s forwards}
@keyframes popIn{from{opacity:0;transform:scale(0.95) translateY(10px)}to{opacity:1;transform:none}}
.modal-close{position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(--gray);font-size:1.2rem;cursor:pointer}
.modal-brand{font-size:1rem;font-weight:700;color:var(--white);margin-bottom:0.3rem}
.modal-brand span{color:var(--blue2)}
.modal h2{font-size:1.6rem;font-weight:700;margin-bottom:0.3rem}
.modal-sub{font-size:0.8rem;color:var(--gray);margin-bottom:1.5rem}
.modal-tabs{display:flex;gap:0;margin-bottom:1.5rem;border-bottom:1px solid var(--border)}
.mtab{background:none;border:none;color:var(--gray);font-family:var(--font);font-size:0.78rem;font-weight:600;padding:0.5rem 1.2rem;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.2s}
.mtab.active{color:var(--blue2);border-bottom-color:var(--blue2)}
.auth-form{display:flex;flex-direction:column;gap:0.9rem}
.form-lbl{font-size:0.7rem;font-weight:600;color:var(--gray);letter-spacing:0.08em;text-transform:uppercase;display:block;margin-bottom:0.3rem}
.form-inp{background:var(--navy3);border:1px solid var(--border);color:var(--white);font-family:var(--font);font-size:0.85rem;padding:0.7rem 1rem;border-radius:6px;outline:none;width:100%;transition:border-color 0.2s}
.form-inp:focus{border-color:var(--blue2)}
.auth-err{font-size:0.72rem;color:var(--red);padding:0.6rem 0.9rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:6px;display:none}
.auth-submit{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.88rem;font-weight:700;padding:0.85rem;border:none;border-radius:8px;cursor:pointer;transition:all 0.2s;margin-top:0.3rem}
.auth-submit:hover{opacity:0.9;transform:translateY(-1px)}

/* ══ EDIT MODAL ══ */

.edit-box h3{font-size:1.3rem;font-weight:700;margin-bottom:0.2rem}
.edit-sub{font-size:0.72rem;color:var(--blue2);margin-bottom:1.2rem}




.edit-cancel:hover{border-color:var(--red);color:var(--red)}

/* ══ DASHBOARD ══ */
#dashPage{min-height:100vh;padding:5rem 3rem 4rem;background:var(--navy)}
.dash-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
.dash-title{font-size:1.8rem;font-weight:800}
.dash-title span{color:var(--blue2)}
.dash-email{font-size:0.78rem;color:var(--gray);margin-top:0.3rem}
.dash-signout{background:none;border:1px solid var(--border);color:var(--gray);font-family:var(--font);font-size:0.78rem;padding:0.5rem 1rem;border-radius:6px;cursor:pointer;transition:all 0.2s}
.dash-signout:hover{border-color:var(--red);color:var(--red)}
.dash-sum{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;margin-bottom:2rem}
.sum-card{background:var(--navy2);border:1px solid var(--border);border-radius:8px;padding:1.2rem 1.5rem}
.sum-lbl{font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray);margin-bottom:0.5rem}
.sum-val{font-size:1.7rem;font-weight:800;color:var(--white)}
.sum-val.up{color:var(--green)}.sum-val.dn{color:var(--red)}
.sum-sub{font-size:0.68rem;color:var(--gray);margin-top:0.2rem}
.dash-grid{display:grid;grid-template-columns:1fr 1.9fr;gap:1.5rem}
.d-card{background:var(--navy2);border:1px solid var(--border);border-radius:8px;padding:1.5rem}
.d-card-title{font-size:0.68rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--blue2);margin-bottom:1.2rem}
.add-form{display:flex;flex-direction:column;gap:0.8rem}
.add-form .form-inp{border-radius:6px}
.add-btn{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.8rem;font-weight:700;padding:0.75rem;border:none;border-radius:6px;cursor:pointer;transition:all 0.2s}
.add-btn:hover{opacity:0.9}
.add-err{font-size:0.7rem;color:var(--red);display:none;margin-top:0.3rem}
.h-tbl{width:100%;border-collapse:collapse}
.h-tbl th{font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray);padding:0 0.9rem 0.8rem;text-align:left;border-bottom:1px solid var(--border)}
.h-tbl td{font-size:0.8rem;padding:0.85rem 0.9rem;border-bottom:1px solid rgba(255,255,255,0.03);font-family:var(--mono)}
.h-tbl tr:last-child td{border-bottom:none}
.h-tbl tr:hover td{background:rgba(79,70,229,0.04)}
.sym{color:var(--blue2);font-weight:600;font-family:var(--font)}
.gain{color:var(--green)}.loss{color:var(--red)}
.tbl-btn{font-family:var(--font);font-size:0.65rem;font-weight:600;padding:0.28rem 0.65rem;border-radius:4px;cursor:pointer;transition:all 0.2s;border:1px solid;margin-right:0.3rem;background:none}
.tbl-edit{border-color:rgba(79,70,229,0.3);color:var(--blue2)}.tbl-edit:hover{background:rgba(79,70,229,0.1)}
.tbl-del{border-color:rgba(239,68,68,0.3);color:var(--red)}.tbl-del:hover{background:rgba(239,68,68,0.1)}
.empty{font-size:0.82rem;color:var(--gray);text-align:center;padding:2.5rem;font-family:var(--mono)}

/* ══ ADMIN ══ */
.admin-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:2px solid var(--blue)}
.admin-ttl{font-size:1.8rem;font-weight:800}
.admin-ttl span{color:var(--blue2)}
.admin-badge{font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;background:rgba(79,70,229,0.15);border:1px solid var(--border2);color:var(--blue2);padding:0.2rem 0.7rem;border-radius:4px;margin-top:0.3rem;display:inline-block}
.admin-users{display:flex;flex-direction:column;gap:1.2rem}
.au-card{background:var(--navy2);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.au-hdr{display:flex;justify-content:space-between;align-items:center;padding:1rem 1.5rem;cursor:pointer;transition:background 0.2s;border-bottom:1px solid transparent}
.au-hdr:hover{background:rgba(79,70,229,0.04)}
.au-email{font-size:0.85rem;font-weight:600}
.au-meta{font-size:0.7rem;color:var(--gray);margin-top:0.2rem;font-family:var(--mono)}
.au-toggle{font-size:0.7rem;color:var(--blue2);font-family:var(--mono)}
.au-body{display:none;padding:1.5rem;border-top:1px solid var(--border)}
.au-body.open{display:block}
.au-add{display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:0.6rem;margin-bottom:1.2rem;align-items:end}
.au-add .form-inp{padding:0.55rem 0.8rem;border-radius:6px;font-size:0.78rem}
.au-add-btn{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-family:var(--font);font-size:0.7rem;font-weight:700;padding:0.55rem 1rem;border:none;border-radius:6px;cursor:pointer;white-space:nowrap}
.loading{font-size:0.82rem;color:var(--gray);text-align:center;padding:2.5rem;font-family:var(--mono)}

/* ══ FOOTER ══ */
footer{background:var(--navy3);border-top:1px solid var(--border);padding:4rem 3rem 2rem}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:4rem;margin-bottom:3rem}
.footer-brand{font-size:1.1rem;font-weight:700;color:var(--white);margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem}
.footer-brand span{color:var(--blue2)}
.footer-desc{font-size:0.8rem;color:var(--gray);line-height:1.9;margin-bottom:1.5rem}
.footer-col h4{font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue2);margin-bottom:1.2rem;padding-bottom:0.5rem;border-bottom:2px solid var(--border2)}
.footer-col ul{list-style:none}
.footer-col ul li{margin-bottom:0.7rem}
.footer-col ul li::before{content:'»';color:var(--blue2);margin-right:0.5rem;font-size:0.8rem}
.footer-col a{font-size:0.82rem;color:var(--gray);text-decoration:none;transition:color 0.2s}
.footer-col a:hover{color:var(--white)}
.footer-bottom{padding-top:2rem;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.footer-copy{font-size:0.75rem;color:var(--gray)}
.footer-legal{font-size:0.68rem;color:var(--gray);opacity:0.6;max-width:55ch;text-align:right;line-height:1.7}
.footer-links{display:flex;gap:1.5rem}
.footer-links a{font-size:0.75rem;color:var(--gray);text-decoration:none}
.footer-links a:hover{color:var(--white)}

@keyframes waPulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.4)}50%{box-shadow:0 4px 30px rgba(37,211,102,0.8)}}
</style>
</head>
<body>

<!-- LIVE EARNINGS NOTIFICATION -->
<div id="earn-notif">
  <div class="en-logo">◈</div>
  <div class="en-content">
    <div><span class="en-name" id="en-name">Caleb</span> from <span class="en-country" id="en-country">Norway</span></div>
    <div class="en-amount" id="en-amount">$80,237</div>
    <div style="color:var(--gray);font-size:0.65rem">just earned on Tabuwul FX</div>
  </div>
</div>

<!-- WHATSAPP -->


<!-- AUTH MODAL -->
<div class="modal-ov" id="authModal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-brand">Tabuwul <span>FX</span></div>
    <h2 id="mTitle">Welcome Back</h2>
    <p class="modal-sub" id="mSub">Sign in to your account</p>
    <div class="modal-tabs">
      <button class="mtab active" id="tabLogin" onclick="switchTab('login')">Sign In</button>
      <button class="mtab" id="tabSignup" onclick="switchTab('signup')">Register</button>
    </div>
    <div class="auth-err" id="authErr"></div>
    <form class="auth-form" onsubmit="handleAuth(event)">
      <div id="nameGrp" style="display:none">
        <label class="form-lbl">Full Name</label>
        <input class="form-inp" type="text" id="authName" placeholder="John Smith">
      </div>
      <div>
        <label class="form-lbl">Email</label>
        <input class="form-inp" type="email" id="authEmail" placeholder="you@example.com" required>
      </div>
      <div>
        <label class="form-lbl">Password</label>
        <input class="form-inp" type="password" id="authPass" placeholder="••••••••" required minlength="6">
      </div>
      <button type="submit" class="auth-submit" id="authBtn">Sign In</button>
    </form>
  </div>
</div>



<!-- PASSWORD GATE MODAL -->
<div class="modal-ov" id="pwGateModal">
  <div class="modal-box" style="max-width:380px">
    <button class="modal-close" onclick="closePwGate()">✕</button>
    <div style="text-align:center;margin-bottom:1.5rem">
      <div style="font-size:2.5rem;margin-bottom:0.5rem">🔐</div>
      <div style="font-size:1.3rem;font-weight:800">Verify Identity</div>
      <div style="font-size:0.8rem;color:var(--gray);margin-top:0.4rem">Enter your password to access your portfolio</div>
    </div>
    <div class="auth-err" id="pwGateErr" style="margin-bottom:1rem"></div>
    <div style="display:flex;flex-direction:column;gap:1rem">
      <div>
        <label class="form-lbl">Password</label>
        <input class="form-inp" type="password" id="pwGateInput" placeholder="Enter your password" onkeydown="if(event.key==='Enter')verifyPwGate()">
      </div>
      <button class="auth-submit" onclick="verifyPwGate()" id="pwGateBtn">Verify & Enter Portfolio</button>
    </div>
  </div>
</div>

<!-- ████ HOME PAGE ████ -->
<div class="page active" id="homePage">

<!-- TOP BAR -->
<div class="topbar">
