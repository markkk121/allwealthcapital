      <div style="width:1px;background:var(--border);align-self:stretch"></div>
      <div class="hstat"><div class="hstat-val">2,400+</div><div class="hstat-lbl">Active Traders</div></div>
      <div style="width:1px;background:var(--border);align-self:stretch"></div>
      <div class="hstat"><div class="hstat-val">24/7</div><div class="hstat-lbl">Market Access</div></div>
    </div>
  </div>
